# Copy this file to backend/.env and fill in real values. Never commit the real .env.

# --- Backend (backend/.env) ---

# MongoDB connection string (MongoDB Atlas or a local mongod).
# Example (Atlas): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/blackcoffer
# Example (local): mongodb://127.0.0.1:27017/blackcoffer
MONGODB_URI=mongodb://127.0.0.1:27017/blackcoffer

# Port the Express API listens on.
PORT=8000

# Allowed browser origin(s) for CORS (the frontend dev server). No wildcards.
# Comma-separated list; include both localhost and 127.0.0.1 since browsers treat
# them as different origins and Vite may be reached via either.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Node environment: development | production | test
NODE_ENV=development


# --- Frontend (frontend/.env) ---
# Vite only exposes vars prefixed with VITE_ to the browser.

# Base URL of the backend API.
VITE_API_BASE_URL=http://localhost:8000
